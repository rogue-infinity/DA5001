# ══════════════════════════════════════════════════════════════════
# DA5001 — Privacy in AI  |  .gitignore
# Keep : *.py, *.sh, *.tex, *.bib, *.sty, requirements*.txt, *.md
#        + compiled report PDFs
# Exclude: weights, tensors, datasets, plots, logs, caches
# ══════════════════════════════════════════════════════════════════

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db

# ── Virtual environments ──────────────────────────────────────────
venv3.11/
venv3.14/
venv*/
.venv/
env/

# ── Python cache ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── PyTorch / NumPy tensors & model weights ───────────────────────
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.npz
*.npy
*.h5
*.hdf5
*.pkl
*.pickle

# ── Model & checkpoint directories ───────────────────────────────
models/
models_backup/
checkpoints/
bundles/

# ── Datasets / raw data ───────────────────────────────────────────
data/
datasets/
*.parquet
*.h5
*.hdf5
*.arrow
*.jsonl.gz
*.csv
*.tsv
!requirements*.txt

# ── HW-specific data ──────────────────────────────────────────────
HW_3/data/

# ── Generated plots & figures ─────────────────────────────────────
**/plots/
**/figs/
*.png
*.jpg
*.jpeg
*.svg
*.eps
# Keep compiled report PDFs (not plot PDFs inside plots/figs dirs)
!Project/Midterm_Report/Midterm_Report.pdf
!Project/*/Logs/*/report.pdf

# ── Experiment logs ───────────────────────────────────────────────
# Note: avoid **/logs/ — case-insensitive macOS FS would match Logs/
# Instead, exclude raw log files by extension and wandb run dirs
*.log
*.out
*.err
# Exclude the inner experiment log directories specifically
**/logs/logs/

# ── Weights & Biases ─────────────────────────────────────────────
wandb/
mlruns/

# ── Result tensors and wandb exports ─────────────────────────────
**/wandb_export/
**/results/
!**/results/*.py

# ── LaTeX build artifacts (keep source & compiled output) ─────────
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb
*.lof
*.lot
!*.tex
!*.bib
!*.sty

# ── dllm subpackage (has own .git) ───────────────────────────────
**/code/dllm/

# ── Jupyter / IPython ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Claude / IDE ──────────────────────────────────────────────────
.claude/
.idea/
.vscode/
*.swp
*~


